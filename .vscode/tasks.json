{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet watch run",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/APSIM.RegistrationV2.csproj"
            ],
            "problemMatcher": "$msCompile",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "type": "dotnet",
            "task": "watch APSIM.RegistrationV2",
            "file": "${workspaceFolder}/APSIM.RegistrationV2.csproj",
            "problemMatcher": [],
            "label": "dotnet: watch APSIM.RegistrationV2"
        }
    ]
}
